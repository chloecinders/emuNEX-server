{
  "db_name": "PostgreSQL",
  "query": "SELECT id, title, image_path, console, category, region, release_year, serial, languages FROM roms\n         WHERE (\n             title ILIKE '%' || $1 || '%'\n             OR serial ILIKE $1 || '%'\n         )\n         AND (category = $2 OR $2 IS NULL)\n         AND (console = $3 OR $3 IS NULL)\n         ORDER BY\n             CASE WHEN serial ILIKE $1 THEN 0 ELSE 1 END,\n             title ASC\n         LIMIT $4 OFFSET $5",
