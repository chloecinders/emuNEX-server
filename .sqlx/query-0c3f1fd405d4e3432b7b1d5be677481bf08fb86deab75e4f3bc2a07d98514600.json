  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id,\n            name,\n            console,\n            platform,\n            run_command,\n            binary_path,\n            binary_name,\n            save_path,\n            md5_hash,\n            config_files as \"config_files!\",\n            zipped as \"zipped!\",\n            file_size as \"file_size!\",\n            created_at\n        FROM emulators\n        WHERE LOWER(console) = LOWER($1) AND platform = $2\n        ORDER BY name ASC\n        ",
