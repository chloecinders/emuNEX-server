{
  "db_name": "PostgreSQL",
  "query": "SELECT r.id, r.title, r.realname, r.console, r.region, r.category, r.serial, r.rom_path, '/covers/' || r.image_hash || '.webp' as \"image_path!\", r.file_extension, r.file_size_bytes, r.md5_hash, r.release_year, r.created_at, r.languages,\n            (SELECT COUNT(*) FROM roms r2 WHERE r2.title = r.title AND r2.console = r.console) as \"versions_count!\"\n           FROM roms r WHERE r.id = $1",
