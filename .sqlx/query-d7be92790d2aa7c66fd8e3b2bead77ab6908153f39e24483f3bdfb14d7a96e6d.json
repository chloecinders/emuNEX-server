  "query": "SELECT ur.id as \"ur_id!\", ur.rom_id, r.title, r.image_path, r.console, ur.play_count, ur.last_played, r.region\n         FROM user_roms ur\n         INNER JOIN roms r ON ur.rom_id = r.id\n         WHERE ur.user_id = $1\n         ORDER BY ur.last_played DESC NULLS LAST",
