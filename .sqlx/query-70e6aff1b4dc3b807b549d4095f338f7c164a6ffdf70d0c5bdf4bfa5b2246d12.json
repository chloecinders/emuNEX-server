  "query": "SELECT rep.id, rep.rom_id, r.title as \"rom_title!\", rep.user_id::TEXT as \"user_id!\", u.username as \"username!\", rep.report_type, rep.description, rep.status, rep.created_at\n         FROM rom_reports rep\n         INNER JOIN roms r ON rep.rom_id = r.id\n         INNER JOIN users u ON rep.user_id = u.id\n         ORDER BY rep.created_at ASC",
