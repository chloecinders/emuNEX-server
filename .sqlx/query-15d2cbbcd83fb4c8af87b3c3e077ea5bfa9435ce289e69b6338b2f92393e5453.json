  "query": "SELECT r.id, r.title, r.image_path, r.console, r.category, r.release_year, r.region, r.serial\n             FROM roms r\n             JOIN shelf_roms sr ON r.id = sr.rom_id\n             WHERE sr.shelf_id = $1\n             ORDER BY sr.sort_order ASC, r.title ASC",
