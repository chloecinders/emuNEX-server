{
  "db_name": "PostgreSQL",
  "query": "SELECT r.id, r.title, r.image_path, r.console, r.category, r.region, r.release_year, r.serial, r.languages\n         FROM roms r\n         LEFT JOIN (\n             SELECT rom_id, SUM(play_count) as total_play_count\n             FROM user_roms\n             GROUP BY rom_id\n         ) ur ON r.id = ur.rom_id\n         ORDER BY COALESCE(ur.total_play_count, 0) DESC, r.title ASC\n         LIMIT 50",
