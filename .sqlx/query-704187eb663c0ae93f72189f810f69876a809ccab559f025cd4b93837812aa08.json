{
  "db_name": "PostgreSQL",
  "query": "\n                    SELECT u.id, u.role as \"role: UserRole\", u.username\n                    FROM users u\n                    JOIN user_tokens ut ON u.id = ut.user_id\n                    WHERE ut.token = $1\n                      AND ut.expires_at > NOW()\n                    ",
