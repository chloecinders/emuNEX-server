{
  "db_name": "PostgreSQL",
  "query": "SELECT id, dat_name, name, serial, md5, crc, sha1, size, clone_of, status\n               FROM nointro_games\n               WHERE (dat_name = $1 OR $1 IS NULL)\n                 AND (\n                     name ILIKE '%' || $2 || '%'\n                     OR serial ILIKE $2 || '%'\n                 )\n               ORDER BY\n                   CASE WHEN serial ILIKE $2 THEN 0 ELSE 1 END,\n                   name ASC\n               LIMIT $3",
