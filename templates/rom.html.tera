<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Upload ROM | emuNEX</title>
        <link rel="stylesheet" href="/public/css/dev.css" />
        <style>
            .nointro-panel {
                background: rgba(var(--color-primary-rgb, 107 92 177) / 0.06);
                border: 1px solid rgba(var(--color-primary-rgb, 107 92 177) / 0.2);
                border-radius: var(--radius-md);
                padding: var(--spacing-md);
                margin-bottom: var(--spacing-lg);
            }
            .nointro-panel .section-hint {
                color: var(--color-primary-light, #9b8fee);
                margin-bottom: var(--spacing-sm);
            }
            .nointro-game-list {
                max-height: 280px;
                overflow-y: auto;
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: var(--radius-sm);
                margin-top: var(--spacing-sm);
            }
            .nointro-game-row {
                display: grid;
                grid-template-columns: 1fr auto auto max-content;
                gap: var(--spacing-sm);
                align-items: center;
                padding: var(--spacing-xs) var(--spacing-sm);
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                font-size: 0.8rem;
            }
            .nointro-game-row:last-child {
                border-bottom: none;
            }
            .nointro-game-row:hover {
                background: rgba(255, 255, 255, 0.04);
            }
            .nointro-game-name {
                font-weight: 700;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }
            .nointro-serial {
                font-family: monospace;
                color: var(--color-text-muted);
                font-size: 0.75rem;
            }
            .nointro-md5 {
                font-family: monospace;
                color: var(--color-text-muted);
                font-size: 0.65rem;
            }
            .nointro-empty {
                padding: var(--spacing-md);
                text-align: center;
                color: var(--color-text-muted);
                font-size: 0.85rem;
            }
        </style>
    </head>
    <body>
        <div class="auth-container" style="max-width: 1200px">
            <div class="auth-card" style="width: 100%">
                <header class="card-header">
                    <a href="/dev" class="back-link">Back</a>
                    <h1>emuNEX</h1>
                    <p class="tagline">Add New ROM to Collection</p>
                </header>

                <div class="content">
                    <div
                        style="
                            display: grid;
                            grid-template-columns: 1fr 1fr;
                            gap: var(--spacing-xl);
                            max-width: 1200px;
                            margin: 0 auto;
                            align-items: start;
                        "
                    >
                        <form
                            id="uploadForm"
                            style="
                                background: rgba(255, 255, 255, 0.02);
                                padding: var(--spacing-lg);
                                border-radius: var(--radius-md);
                                border: 1px solid var(--color-border);
                            "
                        >
                            <div class="section-hint">Game Metadata</div>

                            <input type="hidden" id="title_id" name="title_id" />

                            <div class="form-group">
                                <label for="title">Title</label>
                                <input type="text" id="title" name="title" placeholder="Metroid Fusion" required />
                            </div>

                            <div class="form-group">
                                <label for="md5_hash">MD5 Hash (Hex)</label>
                                <input type="text" id="md5_hash" name="md5_hash" placeholder="1a2b3c4d..." />
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--spacing-md)">
                                <div class="form-group">
                                    <label for="console">Console</label>
                                    <input type="text" id="console" name="console" placeholder="GBA" required />
                                </div>
                                <div class="form-group">
                                    <label for="category">Category</label>
                                    <input type="text" id="category" name="category" placeholder="Action" required />
                                </div>
                                <div class="form-group">
                                    <label for="serial">Serial Number</label>
                                    <input type="text" id="serial" name="serial" placeholder="BJBE" />
                                </div>
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-md)">
                                <div class="form-group">
                                    <label for="region">Region</label>
                                    <input type="text" id="region" name="region" placeholder="USA" />
                                </div>
                                <div class="form-group">
                                    <label for="release_year">Year</label>
                                    <input type="number" id="release_year" name="release_year" placeholder="2002" />
                                </div>
                            </div>

                            <div class="section-hint">Assets</div>

                            <div class="form-group">
                                <label>ROM File</label>
                                <label for="rom_file" class="upload-zone" id="romDropZone">
                                    <div class="upload-icon">↑</div>
                                    <div class="upload-info">
                                        <div class="upload-text">Upload ROM file</div>
                                        <div id="romFileName" class="file-name"></div>
                                    </div>
                                    <input type="file" id="rom_file" name="rom_file" required style="display: none" />
                                </label>
                            </div>

                            <div class="form-group">
                                <label>Cover Image</label>
                                <label for="image_file" class="upload-zone" id="imageDropZone">
                                    <div class="upload-icon">↑</div>
                                    <div class="upload-info">
                                        <div class="upload-text">Upload cover image</div>
                                        <div id="imageFileName" class="file-name"></div>
                                    </div>
                                    <input
                                        type="file"
                                        id="image_file"
                                        name="image_file"
                                        required
                                        style="display: none"
                                    />
                                </label>
                            </div>

                            <button type="submit" id="submitBtn" class="popout-btn">
                                <span class="btn-edge"></span>
                                <span class="btn-front">Upload to Collection</span>
                            </button>
                        </form>

                        <div
                            class="nointro-panel"
                            style="
                                margin: 0;
                                display: flex;
                                flex-direction: column;
                                gap: var(--spacing-sm);
                                height: 100%;
                            "
                        >
                            <div class="section-hint">No-Intro Import</div>

                            <div
                                style="
                                    display: grid;
                                    grid-template-columns: 1fr auto;
                                    gap: var(--spacing-sm);
                                    align-items: end;
                                "
                            >
                                <div class="form-group" style="margin: 0">
                                    <label
                                        for="noIntroFile"
                                        class="upload-zone"
                                        id="datDropZone"
                                        style="padding: var(--spacing-sm); min-height: auto; margin: 0"
                                    >
                                        <div class="upload-info" style="gap: 4px">
                                            <div class="upload-text" style="font-size: 0.8rem">Drop .dat/.xml here</div>
                                            <div id="datFileName" class="file-name" style="font-size: 0.75rem"></div>
                                        </div>
                                        <input type="file" id="noIntroFile" accept=".dat,.xml" style="display: none" />
                                    </label>
                                </div>
                                <button
                                    type="button"
                                    class="popout-btn btn-fit"
                                    id="importDatBtn"
                                    style="margin: 0; min-width: 120px"
                                >
                                    <span class="btn-edge" style="border-radius: var(--radius-sm)"></span>
                                    <span
                                        class="btn-front"
                                        style="
                                            padding: 8px 14px;
                                            border-radius: var(--radius-sm);
                                            font-size: 0.8rem;
                                            min-width: auto;
                                        "
                                        >Import Dump</span
                                    >
                                </button>
                            </div>

                            <div class="form-group">
                                <label for="noIntroDatPicker">Platform</label>
                                <select id="noIntroDatPicker">
                                    <option value="">— select a dat —</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <input
                                    type="text"
                                    id="noIntroSearch"
                                    placeholder="Search games by title or serial..."
                                    oninput="debounceNoIntroSearch()"
                                />
                            </div>

                            <div class="nointro-game-list" id="noIntroGameList" style="flex: 1; min-height: 300px">
                                <div class="nointro-empty">Select a platform to browse games</div>
                            </div>

                            <div class="form-group" style="margin-top: var(--spacing-md)">
                                <label for="datNotes">Admin Notes</label>
                                <textarea
                                    id="datNotes"
                                    placeholder="Serial formats for this platform, known issues..."
                                    style="min-height: 120px; font-size: 0.85rem; background: rgba(0, 0, 0, 0.2)"
                                    oninput="debounceSaveNotes()"
                                ></textarea>
                            </div>
                        </div>
                    </div>
                    <div
                        id="statusBox"
                        class="status-box"
                        style="margin-top: var(--spacing-xl); max-width: 1200px; margin-left: auto; margin-right: auto"
                    ></div>
                </div>
            </div>
        </div>

        <script>
            const token = localStorage.getItem("token");
            let noIntroSearchTimeout;
            let notesSaveTimeout;
            let currentDat = "";
            let datNotesData = {};
            let lastSearchGames = [];

            async function loadDats() {
                try {
                    const res = await fetch("/api/v1/nointro/dats", { headers: { Authorization: token } });
                    const json = await res.json();
                    const picker = document.getElementById("noIntroDatPicker");

                    picker.innerHTML = '<option value=""> select a dump </option>';

                    (json.data || []).forEach((dat) => {
                        const opt = document.createElement("option");
                        const name = typeof dat === "string" ? dat : dat.name || "Unknown";
                        const notes = typeof dat === "string" ? "" : dat.notes || "";

                        opt.value = name;
                        opt.textContent = name;
                        picker.appendChild(opt);
                        datNotesData[name] = notes;
                    });
                } catch {}
            }

            document.getElementById("noIntroDatPicker").addEventListener("change", function () {
                currentDat = this.value;
                document.getElementById("noIntroSearch").value = "";
                document.getElementById("datNotes").value = datNotesData[currentDat] || "";

                if (currentDat) searchNoIntro("");
                else
                    document.getElementById("noIntroGameList").innerHTML =
                        '<div class="nointro-empty">Select a platform to browse games</div>';
            });

            document.getElementById("importDatBtn").addEventListener("click", async () => {
                const file = document.getElementById("noIntroFile").files[0];
                if (!file) {
                    showNoIntroStatus("Pick a .dat file first");
                    return;
                }

                const btn = document.getElementById("importDatBtn").querySelector(".btn-front");
                btn.textContent = "Importing…";

                const fd = new FormData();
                fd.append("dat_file", file);

                try {
                    const res = await fetch("/api/v1/nointro/import", {
                        method: "POST",
                        headers: { Authorization: token },
                        body: fd,
                    });
                    const json = await res.json();
                    if (res.ok) {
                        showNoIntroStatus(`✓ Imported ${json.data.imported} games`);
                        await loadDats();
                    } else {
                        showNoIntroStatus(`Error: ${json.error || "import failed"}`);
                    }
                } catch {
                    showNoIntroStatus("Network error during import");
                } finally {
                    btn.textContent = "Import Dump";
                }
            });

            function debounceNoIntroSearch() {
                clearTimeout(noIntroSearchTimeout);
                noIntroSearchTimeout = setTimeout(() => {
                    searchNoIntro(document.getElementById("noIntroSearch").value);
                }, 300);
            }

            async function searchNoIntro(query) {
                if (!currentDat) return;
                const list = document.getElementById("noIntroGameList");
                list.innerHTML = '<div class="nointro-empty">Searching…</div>';

                const params = new URLSearchParams({ dat: currentDat, limit: "100" });
                if (query) params.set("query", query);

                try {
                    const res = await fetch(`/api/v1/nointro/search?${params}`, { headers: { Authorization: token } });
                    const json = await res.json();
                    lastSearchGames = json.data || [];
                    renderNoIntroGames(lastSearchGames);
                } catch {
                    list.innerHTML = '<div class="nointro-empty">Search failed</div>';
                }
            }

            function renderNoIntroGames(games) {
                const list = document.getElementById("noIntroGameList");
                if (!games.length) {
                    list.innerHTML = '<div class="nointro-empty">No games found</div>';
                    return;
                }
                list.innerHTML = games
                    .map((g, idx) => {
                        const name = g.name || "Unknown Game";
                        const serial = g.serial || "—";
                        const md5 = (g.md5 || "").slice(0, 8);

                        return `
                        <div class="nointro-game-row">
                            <span class="nointro-game-name" title="${escapeHtml(name)}">${escapeHtml(name)}</span>
                            <span class="nointro-serial">${escapeHtml(serial)}</span>
                            <span class="nointro-md5">${escapeHtml(md5)}…</span>
                            <button class="popout-btn btn-fit" onclick="selectNoIntroGameByIndex(${idx})">
                                <span class="btn-edge" style="border-radius: var(--radius-sm)"></span>
                                <span class="btn-front" style="padding: 6px 12px; border-radius: var(--radius-sm); font-size: 0.75rem; min-width: auto;">Select</span>
                            </button>
                        </div>
                    `;
                    })
                    .join("");
            }

            function selectNoIntroGameByIndex(idx) {
                if (lastSearchGames[idx]) {
                    selectNoIntroGame(lastSearchGames[idx]);
                }
            }

            function selectNoIntroGame(game) {
                if (!game) return;
                document.getElementById("title").value = game.name || "";
                document.getElementById("title_id").value = game.id || "";
                document.getElementById("serial").value = game.serial || "";
                document.getElementById("md5_hash").value = game.md5 || "";

                const statusBox = document.getElementById("statusBox");
                statusBox.innerText = `Matched with No-Intro: ${game.name || "Unknown"}`;
                statusBox.className = "status-box status-success";
                statusBox.style.display = "block";
            }

            function showNoIntroStatus(msg) {
                const statusBox = document.getElementById("statusBox");
                statusBox.innerText = msg;
                statusBox.className = "status-box status-success";
                statusBox.style.display = "block";
            }

            function debounceSaveNotes() {
                if (!currentDat) return;
                clearTimeout(notesSaveTimeout);
                notesSaveTimeout = setTimeout(async () => {
                    const notes = document.getElementById("datNotes").value;
                    datNotesData[currentDat] = notes;

                    try {
                        await fetch(`/api/v1/nointro/dats/${encodeURIComponent(currentDat)}/notes`, {
                            method: "POST",
                            headers: {
                                Authorization: token,
                                "Content-Type": "application/json",
                            },
                            body: JSON.stringify({ notes }),
                        });
                    } catch (e) {
                        console.error("Failed to save notes", e);
                    }
                }, 1000);
            }

            function escapeHtml(s) {
                return String(s)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;");
            }

            function setupUploadZone(zoneId, inputId, nameId) {
                const zone = document.getElementById(zoneId);
                const input = document.getElementById(inputId);
                const display = document.getElementById(nameId);

                input.addEventListener("change", () => {
                    if (input.files.length) display.textContent = input.files[0].name;
                });

                ["dragenter", "dragover"].forEach((name) => {
                    zone.addEventListener(name, (e) => {
                        e.preventDefault();
                        zone.classList.add("dragover");
                    });
                });

                ["dragleave", "drop"].forEach((name) => {
                    zone.addEventListener(name, (e) => {
                        e.preventDefault();
                        zone.classList.remove("dragover");
                    });
                });

                zone.addEventListener("drop", (e) => {
                    input.files = e.dataTransfer.files;
                    if (input.files.length) display.textContent = input.files[0].name;
                });
            }

            setupUploadZone("romDropZone", "rom_file", "romFileName");
            setupUploadZone("imageDropZone", "image_file", "imageFileName");
            setupUploadZone("datDropZone", "noIntroFile", "datFileName");

            document.getElementById("uploadForm").addEventListener("submit", async (e) => {
                e.preventDefault();

                const btn = document.getElementById("submitBtn");
                const statusBox = document.getElementById("statusBox");
                const formData = new FormData(e.target);

                if (!formData.get("title_id")) {
                    const titleRaw = formData.get("title") || "";
                    formData.set(
                        "title_id",
                        titleRaw
                            .replace(/\s+/g, "_")
                            .replace(/[^a-zA-Z0-9_\-]/g, "")
                            .slice(0, 64) || `ROM_${Date.now()}`,
                    );
                }

                btn.disabled = true;
                statusBox.innerText = "Processing upload...";
                statusBox.className = "status-box status-success";
                statusBox.style.display = "block";

                try {
                    const response = await fetch("/api/v1/roms/upload", {
                        method: "POST",
                        body: formData,
                        headers: { Authorization: token },
                    });

                    const result = await response.json();

                    if (response.ok) {
                        statusBox.innerText = `Success! ROM ID: ${result.data}`;
                        statusBox.className = "status-box status-success";
                        e.target.reset();
                        document.getElementById("romFileName").textContent = "";
                        document.getElementById("imageFileName").textContent = "";
                    } else {
                        statusBox.innerText = `Error: ${result.error || "Upload failed"}`;
                        statusBox.className = "status-box status-error";
                    }
                } catch (err) {
                    statusBox.innerText = "A network error occurred.";
                    statusBox.className = "status-box status-error";
                } finally {
                    btn.disabled = false;
                }
            });

            loadDats();
        </script>
    </body>
</html>
