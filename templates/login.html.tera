<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Authentication | emuNEX</title>
    <script type="importmap">{% raw %}
      {
        "imports": {
          "lit": "https://esm.sh/lit@3",
          "lit/decorators.js": "https://esm.sh/lit@3/decorators.js"
        }
      }
    {% endraw %}</script>
    <link rel="stylesheet" href="/public/css/auth.css">
  </head>
    <body>
        <emunex-auth-page auth-type="{{ auth_type }}" domain="{{ domain | safe }}"></emunex-auth-page>
        <script type="module" src="/public/js/auth-page.js"></script>
    </body>
</html>
