<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>User Management | emuNEX</title>
        <link rel="stylesheet" href="/public/css/dev.css" />
    </head>
    <body>
        <div class="auth-container" style="max-width: 800px;">
            <div class="auth-card">
                <header class="card-header">
                    <a href="/dev" class="back-link">Back</a>
                    <h1>emuNEX</h1>
                </header>

                <div class="content">
                    <div style="overflow-x: auto;">
                        <table>
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Role</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for user in users %}
                                <tr data-id="{{ user.id }}">
                                    <td style="font-family: monospace; font-weight: 700; color: var(--color-text-muted);">#{{ user.id }}</td>
                                    <td>
                                        <input type="text" class="edit-username" value="{{ user.username }}" style="padding: var(--spacing-sm); font-weight: 700;" />
                                    </td>
                                    <td>
                                        <select class="edit-role" style="padding: var(--spacing-sm); font-weight: 700;">
                                            <option value="user" {% if user.role == "user" %}selected{% endif %}>User</option>
                                            <option value="moderator" {% if user.role == "moderator" %}selected{% endif %}>Moderator</option>
                                            <option value="admin" {% if user.role == "admin" %}selected{% endif %}>Admin</option>
                                        </select>
                                    </td>
                                    <td>
                                        <button class="popout-btn" onclick="saveUser({{ user.id }})" style="margin: 0; min-width: 80px;">
                                            <span class="btn-edge" style="border-radius: var(--radius-sm);"></span>
                                            <span class="btn-front" style="padding: 6px 12px; border-radius: var(--radius-sm); font-size: 0.8rem;">Save</span>
                                        </button>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div id="statusBox" class="status-box"></div>

                    <div style="margin-top: 40px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <h2 style="margin: 0;">Invite Codes</h2>
                            <button class="popout-btn" onclick="generateInvite()" style="margin: 0; min-width: 150px;">
                                <span class="btn-edge"></span>
                                <span class="btn-front">Generate Code</span>
                            </button>
                        </div>

                        <table>
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Status</th>
                                    <th>Created At</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="inviteTableBody">
                                {% for invite in invites %}
                                <tr data-code="{{ invite.code }}">
                                    <td style="font-family: monospace; font-weight: 700;">{{ invite.code }}</td>
                                    <td>
                                        {% if invite.used_by_username %}
                                        <span style="color: var(--color-text-muted);">Used by <strong>{{ invite.used_by_username }}</strong></span>
                                        {% else %}
                                        <span style="color: #48bb78; font-weight: 700;">Unused</span>
                                        {% endif %}
                                    </td>
                                    <td style="font-size: 0.8rem; color: var(--color-text-muted);">
                                        {% if invite.created_at %}
                                        {{ invite.created_at | date(format="%Y-%m-%d %H:%M") }}
                                        {% else %}
                                        -
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if not invite.used_by_username %}
                                        <button class="popout-btn" onclick="deleteInvite('{{ invite.code }}')" style="margin: 0; min-width: 80px;">
                                            <span class="btn-edge" style="border-radius: var(--radius-sm); background: #f56565;"></span>
                                            <span class="btn-front" style="padding: 6px 12px; border-radius: var(--radius-sm); font-size: 0.8rem; background: #e53e3e;">Delete</span>
                                        </button>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <script>
            const token = localStorage.getItem("token");

            async function saveUser(userId) {
                const row = document.querySelector(`tr[data-id="${userId}"]`);
                const username = row.querySelector(".edit-username").value;
                const role = row.querySelector(".edit-role").value;
                const statusBox = document.getElementById("statusBox");

                statusBox.innerText = "Saving changes...";
                statusBox.className = "status-box status-success";
                statusBox.style.display = "block";

                try {
                    const response = await fetch(`/api/v1/users/${userId}`, {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json",
                            "Authorization": token
                        },
                        body: JSON.stringify({ username, role })
                    });

                    if (response.ok) {
                        statusBox.innerText = `User ${username} updated successfully!`;
                        statusBox.className = "status-box status-success";
                    } else {
                        const result = await response.json();
                        statusBox.innerText = `Error: ${result.error || "Update failed"}`;
                        statusBox.className = "status-box status-error";
                    }
                } catch (err) {
                    statusBox.innerText = "A network error occurred.";
                    statusBox.className = "status-box status-error";
                }
            }

            async function generateInvite() {
                const statusBox = document.getElementById("statusBox");
                statusBox.innerText = "Generating invite code...";
                statusBox.className = "status-box status-success";
                statusBox.style.display = "block";

                try {
                    const response = await fetch("/api/v1/invites", {
                        method: "POST",
                        headers: { "Authorization": token }
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        const result = await response.json();
                        statusBox.innerText = `Error: ${result.error || "Generation failed"}`;
                        statusBox.className = "status-box status-error";
                    }
                } catch (err) {
                    statusBox.innerText = "A network error occurred.";
                    statusBox.className = "status-box status-error";
                }
            }

            async function deleteInvite(code) {
                if (!confirm(`Are you sure you want to delete invite code ${code}?`)) return;

                const statusBox = document.getElementById("statusBox");
                try {
                    const response = await fetch(`/api/v1/invites/${code}`, {
                        method: "DELETE",
                        headers: { "Authorization": token }
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        const result = await response.json();
                        statusBox.innerText = `Error: ${result.error || "Deletion failed"}`;
                        statusBox.className = "status-box status-error";
                        statusBox.style.display = "block";
                    }
                } catch (err) {
                    statusBox.innerText = "A network error occurred.";
                    statusBox.className = "status-box status-error";
                    statusBox.style.display = "block";
                }
            }
        </script>
    </body>
</html>
