<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>ROM Management | emuNEX</title>
        <link rel="stylesheet" href="/public/css/dev.css" />
    </head>
    <body>
        <div class="auth-container" style="max-width: 1000px">
            <div class="auth-card">
                <header class="card-header">
                    <a href="/dev" class="back-link">Back</a>
                    <h1>emuNEX</h1>
                </header>

                <div class="content">
                    <div
                        style="
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            margin-bottom: var(--spacing-md);
                        "
                    >
                        <a href="/roms/upload" class="popout-btn btn-fit" style="margin: 0; text-decoration: none">
                            <span class="btn-edge" style="border-radius: var(--radius-sm)"></span>
                            <span
                                class="btn-front"
                                style="
                                    padding: 6px 12px;
                                    border-radius: var(--radius-sm);
                                    font-size: 0.8rem;
                                    min-width: auto;
                                "
                                >+ Add New ROM</span
                            >
                        </a>
                    </div>

                    <div class="form-group" style="margin-bottom: var(--spacing-md)">
                        <input
                            type="text"
                            id="romSearch"
                            placeholder="Search ROMs by title..."
                            style="font-weight: 700"
                            oninput="debounceSearch()"
                        />
                    </div>

                    <div style="overflow-x: auto">
                        <table id="romTable">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Title</th>
                                    <th>Console</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>

                            <tbody id="romTableBody"></tbody>
                        </table>
                    </div>

                    <div id="statusBox" class="status-box"></div>
                </div>
            </div>
        </div>

        <div
            id="editModal"
            style="
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.85);
                z-index: 1000;
                align-items: center;
                justify-content: center;
                padding: var(--spacing-md);
                backdrop-filter: blur(4px);
            "
        >
            <div class="auth-card" style="max-width: 600px; width: 100%; max-height: 90vh; overflow-y: auto">
                <div class="content">
                    <div class="section-hint">Edit ROM Metadata</div>
                    <form id="editForm">
                        <input type="hidden" id="edit-id" />

                        <div class="form-group">
                            <label>Title</label>
                            <input type="text" id="edit-title" required />
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-md)">
                            <div class="form-group">
                                <label>Console</label>
                                <input type="text" id="edit-console" required />
                            </div>
                            <div class="form-group">
                                <label>Category</label>
                                <input type="text" id="edit-category" required />
                            </div>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-md)">
                            <div class="form-group">
                                <label>Region</label>
                                <input type="text" id="edit-region" placeholder="USA, Japan" />
                            </div>
                            <div class="form-group">
                                <label>Release Year</label>
                                <input type="number" id="edit-year" placeholder="1996" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>ROM File</label>
                            <label for="edit-file" class="upload-zone" id="edit-rom-zone">
                                <div class="upload-icon">↑</div>
                                <div class="upload-info">
                                    <div class="upload-text">Upload ROM file</div>
                                    <div id="edit-rom-name" class="file-name"></div>
                                </div>
                                <input type="file" id="edit-file" style="display: none" />
                            </label>
                        </div>

                        <div class="form-group">
                            <label>Box Art</label>
                            <label for="edit-image" class="upload-zone" id="edit-image-zone">
                                <div class="upload-icon">↑</div>
                                <div class="upload-info">
                                    <div class="upload-text">Upload box art</div>
                                    <div id="edit-image-name" class="file-name"></div>
                                </div>
                                <input type="file" id="edit-image" accept="image/*" style="display: none" />
                            </label>
                        </div>

                        <div style="display: flex; gap: var(--spacing-md); margin-top: var(--spacing-lg)">
                            <button type="submit" class="popout-btn btn-fit btn-info" style="flex: 1; margin: 0">
                                <span class="btn-edge"></span>
                                <span class="btn-front" style="padding: 10px">Save Changes</span>
                            </button>
                            <button
                                type="button"
                                class="popout-btn btn-fit"
                                onclick="closeModal()"
                                style="flex: 1; margin: 0; --btn-color-primary: #666; --btn-color-dark: #333"
                            >
                                <span class="btn-edge"></span>
                                <span class="btn-front" style="padding: 10px">Cancel</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script>
            let searchTimeout;
            let allRoms = [];
            const token = localStorage.getItem("token");

            async function fetchRoms(query = "") {
                const body = document.getElementById("romTableBody");
                body.innerHTML =
                    '<tr><td colspan="4" style="text-align: center; padding: var(--spacing-xl);">Loading library...</td></tr>';

                try {
                    const url = query
                        ? `/api/v1/roms/search?query=${encodeURIComponent(query)}`
                        : `/api/v1/roms/list?limit=100`;

                    const response = await fetch(url, {
                        headers: { Authorization: token },
                    });
                    const result = await response.json();

                    if (response.ok) {
                        allRoms = result.data;
                        renderTable(allRoms);
                    } else {
                        body.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--color-error);">Error: ${result.error}</td></tr>`;
                    }
                } catch (err) {
                    body.innerHTML =
                        '<tr><td colspan="4" style="text-align: center; color: var(--color-error);">A network error occurred.</td></tr>';
                }
            }

            function renderTable(roms) {
                const body = document.getElementById("romTableBody");
                body.innerHTML = "";

                if (roms.length === 0) {
                    body.innerHTML =
                        '<tr><td colspan="4" style="text-align: center; padding: var(--spacing-xl);">No ROMs found.</td></tr>';
                    return;
                }

                roms.forEach((rom) => {
                    const row = document.createElement("tr");
                    row.innerHTML = `
                        <td style="font-family: monospace; font-weight: 700; color: var(--color-text-muted);">#${rom.id}</td>
                        <td style="font-weight: 700;">${rom.title}</td>
                        <td style="font-weight: 800;">${rom.console}</td>
                        <td style="display: flex; gap: var(--spacing-xs);">
                            <button class="popout-btn btn-fit btn-info" onclick="openEdit(${rom.id})" style="margin: 0;">
                                <span class="btn-edge" style="border-radius: var(--radius-sm);"></span>
                                <span class="btn-front" style="padding: 4px 10px; border-radius: var(--radius-sm); font-size: 0.75rem; min-width: 60px;">Edit</span>
                            </button>
                            <button class="popout-btn btn-fit btn-error" onclick="deleteRom(${rom.id}, this)" style="margin: 0;">
                                <span class="btn-edge" style="border-radius: var(--radius-sm);"></span>
                                <span class="btn-front" style="padding: 4px 10px; border-radius: var(--radius-sm); font-size: 0.75rem; min-width: 60px;">Delete</span>
                            </button>
                        </td>
                    `;
                    body.appendChild(row);
                });
            }

            function debounceSearch() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    fetchRoms(document.getElementById("romSearch").value);
                }, 300);
            }

            function openEdit(id) {
                const rom = allRoms.find((r) => r.id === id);
                if (!rom) return;

                document.getElementById("edit-id").value = rom.id;
                document.getElementById("edit-title").value = rom.title;
                document.getElementById("edit-console").value = rom.console;
                document.getElementById("edit-category").value = rom.category || "";
                document.getElementById("edit-region").value = rom.region || "";
                document.getElementById("edit-year").value = rom.release_year || "";

                document.getElementById("edit-file").value = "";
                document.getElementById("edit-image").value = "";
                document.getElementById("edit-rom-name").textContent = "";
                document.getElementById("edit-image-name").textContent = "";

                document.getElementById("editModal").style.display = "flex";
            }

            function closeModal() {
                document.getElementById("editModal").style.display = "none";
            }

            function setupUploadZone(zoneId, inputId, nameId) {
                const zone = document.getElementById(zoneId);
                const input = document.getElementById(inputId);
                const display = document.getElementById(nameId);

                input.addEventListener("change", () => {
                    if (input.files.length) display.textContent = input.files[0].name;
                });

                ["dragenter", "dragover"].forEach((name) => {
                    zone.addEventListener(name, (e) => {
                        e.preventDefault();
                        zone.classList.add("dragover");
                    });
                });

                ["dragleave", "drop"].forEach((name) => {
                    zone.addEventListener(name, (e) => {
                        e.preventDefault();
                        zone.classList.remove("dragover");
                    });
                });

                zone.addEventListener("drop", (e) => {
                    input.files = e.dataTransfer.files;
                    if (input.files.length) display.textContent = input.files[0].name;
                });
            }

            setupUploadZone("edit-rom-zone", "edit-file", "edit-rom-name");
            setupUploadZone("edit-image-zone", "edit-image", "edit-image-name");

            document.getElementById("editForm").addEventListener("submit", async (e) => {
                e.preventDefault();
                const id = document.getElementById("edit-id").value;
                const updateData = {
                    title: document.getElementById("edit-title").value,
                    console: document.getElementById("edit-console").value,
                    category: document.getElementById("edit-category").value,
                    region: document.getElementById("edit-region").value || null,
                    release_year: parseInt(document.getElementById("edit-year").value) || null,
                };

                try {
                    const response = await fetch(`/api/v1/roms/${id}`, {
                        method: "PUT",
                        headers: { Authorization: token, "Content-Type": "application/json" },
                        body: JSON.stringify(updateData),
                    });

                    if (!response.ok) {
                        const err = await response.json();
                        throw new Error(err.error || "Metadata update failed");
                    }

                    const fileInput = document.getElementById("edit-file");
                    const imageInput = document.getElementById("edit-image");

                    if (fileInput.files.length > 0) {
                        const formData = new FormData();
                        formData.append("file", fileInput.files[0]);
                        const fRes = await fetch(`/api/v1/roms/${id}/file`, {
                            method: "POST",
                            headers: { Authorization: token },
                            body: formData,
                        });
                        if (!fRes.ok) throw new Error("ROM file upload failed");
                    }

                    if (imageInput.files.length > 0) {
                        const formData = new FormData();
                        formData.append("image", imageInput.files[0]);
                        const iRes = await fetch(`/api/v1/roms/${id}/image`, {
                            method: "POST",
                            headers: { Authorization: token },
                            body: formData,
                        });
                        if (!iRes.ok) throw new Error("Box art upload failed");
                    }

                    showStatus(`ROM updated successfully!`, "success");
                    closeModal();
                    fetchRoms(document.getElementById("romSearch").value);
                } catch (err) {
                    showStatus(err.message || "Update failed.", "error");
                }
            });

            async function deleteRom(id, btn) {
                if (!confirm(`Are you sure you want to delete ROM #${id}?`)) return;

                try {
                    const response = await fetch(`/api/v1/roms/${id}`, {
                        method: "DELETE",
                        headers: { Authorization: token },
                    });

                    if (response.ok) {
                        btn.closest("tr").remove();
                        showStatus(`ROM #${id} deleted.`, "success");
                    } else {
                        const err = await response.json();
                        showStatus(`Error: ${err.error}`, "error");
                    }
                } catch (err) {
                    showStatus("Deletion failed.", "error");
                }
            }

            function showStatus(msg, type) {
                const sb = document.getElementById("statusBox");
                sb.innerText = msg;
                sb.className = `status-box status-${type}`;
                sb.style.display = "block";
                setTimeout(() => (sb.style.display = "none"), 3000);
            }

            fetchRoms();
        </script>
    </body>
</html>
