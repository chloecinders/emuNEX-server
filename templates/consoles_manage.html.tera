<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Console Management | emuNEX</title>
        <link rel="stylesheet" href="/public/css/dev.css" />
    </head>
    <body>
        <div class="auth-container" style="max-width: 800px">
            <div class="auth-card">
                <header class="card-header">
                    <a href="/dev" class="back-link">Back</a>
                    <h1>emuNEX</h1>
                </header>

                <div class="content">
                    <div
                        style="
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            margin-bottom: var(--spacing-md);
                        "
                    >
                        <a href="/consoles/upload" class="popout-btn btn-fit" style="margin: 0; text-decoration: none">
                            <span class="btn-edge" style="border-radius: var(--radius-sm)"></span>
                            <span
                                class="btn-front"
                                style="
                                    padding: 6px 12px;
                                    border-radius: var(--radius-sm);
                                    font-size: 0.8rem;
                                    min-width: auto;
                                "
                                >+ Add Console</span
                            >
                        </a>
                    </div>

                    <div class="form-group" style="margin-bottom: var(--spacing-md)">
                        <input
                            type="text"
                            id="consoleSearch"
                            placeholder="Search consoles by name..."
                            style="font-weight: 700"
                            oninput="debounceSearch()"
                        />
                    </div>

                    <div style="overflow-x: auto">
                        <table style="margin-top: 0">
                            <thead>
                                <tr>
                                    <th>Console Name</th>
                                    <th>Card Accent</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="consoleTableBody"> </tbody>
                        </table>
                    </div>

                    <div id="statusBox" class="status-box"></div>
                </div>
            </div>
        </div>

        <div
            id="editModal"
            style="
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.85);
                z-index: 1000;
                align-items: center;
                justify-content: center;
                padding: var(--spacing-md);
                backdrop-filter: blur(4px);
            "
        >
            <div class="auth-card" style="max-width: 450px; width: 100%">
                <div class="content">
                    <div class="section-hint">Edit Console Metadata</div>
                    <form id="editForm">
                        <div class="form-group">
                            <label>Console Name (Read-only)</label>
                            <input type="text" id="edit-name" readonly style="opacity: 0.7; cursor: not-allowed" />
                        </div>

                        <div class="form-group">
                            <label>Card Accent Color</label>
                            <div style="display: flex; gap: var(--spacing-sm); align-items: center">
                                <input
                                    type="text"
                                    id="edit-color-hex"
                                    placeholder="#ff0000"
                                    style="flex: 1; font-family: monospace; text-transform: uppercase"
                                    oninput="syncEditColorFromHex(this.value)"
                                />
                                <input
                                    type="color"
                                    id="edit-color-picker"
                                    style="display: none"
                                    oninput="syncEditColorFromPicker(this.value)"
                                />
                                <div
                                    id="edit-color-preview"
                                    onclick="document.getElementById('edit-color-picker').click()"
                                    style="
                                        width: 42px;
                                        height: 42px;
                                        border-radius: var(--radius-sm);
                                        border: 2px solid var(--color-border);
                                        background: #333;
                                        cursor: pointer;
                                        flex-shrink: 0;
                                        transition: transform 0.1s;
                                    "
                                    onmousedown="this.style.transform = 'scale(0.95)'"
                                    onmouseup="this.style.transform = 'scale(1)'"
                                    onmouseleave="this.style.transform = 'scale(1)'"
                                ></div>
                            </div>
                        </div>

                        <div style="display: flex; gap: var(--spacing-md); margin-top: var(--spacing-lg)">
                            <button type="submit" class="popout-btn btn-fit btn-info" style="flex: 1; margin: 0">
                                <span class="btn-edge"></span>
                                <span class="btn-front" style="padding: 10px">Save Changes</span>
                            </button>
                            <button
                                type="button"
                                class="popout-btn btn-fit"
                                onclick="closeModal()"
                                style="flex: 1; margin: 0; --btn-color-primary: #666; --btn-color-dark: #333"
                            >
                                <span class="btn-edge"></span>
                                <span class="btn-front" style="padding: 10px">Cancel</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script>
            function syncEditColorFromHex(hex) {
                const preview = document.getElementById("edit-color-preview");
                const picker = document.getElementById("edit-color-picker");
                if (/^#[0-9A-F]{6}$/i.test(hex)) {
                    preview.style.backgroundColor = hex;
                    picker.value = hex;
                }
            }

            function syncEditColorFromPicker(hex) {
                document.getElementById("edit-color-hex").value = hex.toUpperCase();
                document.getElementById("edit-color-preview").style.backgroundColor = hex;
            }

            let searchTimeout;
            let allConsoles = [];
            const token = localStorage.getItem("token");

            async function fetchConsoles() {
                const body = document.getElementById("consoleTableBody");
                body.innerHTML =
                    '<tr><td colspan="3" style="text-align: center; padding: var(--spacing-xl);">Loading consoles...</td></tr>';

                try {
                    const response = await fetch("/api/v1/consoles", {
                        headers: { Authorization: token },
                    });
                    const result = await response.json();

                    if (response.ok) {
                        allConsoles = result.data;
                        renderTable(allConsoles);
                    } else {
                        body.innerHTML = `<tr><td colspan="3" style="text-align: center; color: var(--color-error);">Error: ${result.error}</td></tr>`;
                    }
                } catch (err) {
                    body.innerHTML =
                        '<tr><td colspan="3" style="text-align: center; color: var(--color-error);">A network error occurred.</td></tr>';
                }
            }

            function renderTable(consoles) {
                const body = document.getElementById("consoleTableBody");
                body.innerHTML = "";

                if (consoles.length === 0) {
                    body.innerHTML =
                        '<tr><td colspan="3" style="text-align: center; padding: var(--spacing-xl);">No consoles found.</td></tr>';
                    return;
                }

                consoles.forEach((console) => {
                    const row = document.createElement("tr");
                    row.innerHTML = `
                        <td style="font-weight: 700;">${console.name}</td>
                        <td>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <div style="width: 20px; height: 20px; border-radius: 4px; background: ${console.card_color || "#333"}; border: 1px solid var(--color-border);"></div>
                                <code style="font-size: 0.8rem; opacity: 0.8; font-family: inherit;">${console.card_color || "Default"}</code>
                            </div>
                        </td>
                        <td style="display: flex; gap: var(--spacing-xs);">
                            <button class="popout-btn btn-fit btn-info" onclick="openEdit('${console.name}')" style="margin: 0;">
                                <span class="btn-edge" style="border-radius: var(--radius-sm);"></span>
                                <span class="btn-front" style="padding: 4px 10px; border-radius: var(--radius-sm); font-size: 0.75rem; min-width: 60px;">Edit</span>
                            </button>
                            <button class="popout-btn btn-fit btn-error" onclick="deleteConsole('${console.name}', this)" style="margin: 0;">
                                <span class="btn-edge" style="border-radius: var(--radius-sm);"></span>
                                <span class="btn-front" style="padding: 4px 10px; border-radius: var(--radius-sm); font-size: 0.75rem; min-width: 60px;">Delete</span>
                            </button>
                        </td>
                    `;
                    body.appendChild(row);
                });
            }

            function debounceSearch() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    const q = document.getElementById("consoleSearch").value.toLowerCase();
                    const filtered = allConsoles.filter((c) => c.name.toLowerCase().includes(q));
                    renderTable(filtered);
                }, 300);
            }

            function openEdit(name) {
                const console = allConsoles.find((c) => c.name === name);
                if (!console) return;

                document.getElementById("edit-name").value = console.name;
                const color = console.card_color || "#333333";
                document.getElementById("edit-color-hex").value = color;
                document.getElementById("edit-color-picker").value = color;
                document.getElementById("edit-color-preview").style.backgroundColor = color;
                document.getElementById("editModal").style.display = "flex";
            }

            function closeModal() {
                document.getElementById("editModal").style.display = "none";
            }

            document.getElementById("editForm").addEventListener("submit", async (e) => {
                e.preventDefault();
                const name = document.getElementById("edit-name").value;
                const color = document.getElementById("edit-color-hex").value;

                try {
                    const response = await fetch(`/api/v1/consoles/${name}/metadata`, {
                        method: "PUT",
                        headers: { Authorization: token, "Content-Type": "application/json" },
                        body: JSON.stringify({ card_color: color }),
                    });

                    if (response.ok) {
                        showStatus(`Console updated!`, "success");
                        closeModal();
                        fetchConsoles();
                    } else {
                        const err = await response.json();
                        showStatus(`Error: ${err.error}`, "error");
                    }
                } catch (err) {
                    showStatus("Update failed.", "error");
                }
            });

            async function deleteConsole(name, btn) {
                if (!confirm(`Are you sure you want to delete the console '${name}'?`)) return;

                try {
                    const response = await fetch(`/api/v1/consoles/${encodeURIComponent(name)}`, {
                        method: "DELETE",
                        headers: { Authorization: token },
                    });

                    if (response.ok) {
                        btn.closest("tr").remove();
                        showStatus(`Console ${name} deleted.`, "success");
                    } else {
                        const err = await response.json();
                        showStatus(`Error: ${err.error}`, "error");
                    }
                } catch (err) {
                    showStatus("Deletion failed.", "error");
                }
            }

            function showStatus(msg, type) {
                const sb = document.getElementById("statusBox");
                sb.innerText = msg;
                sb.className = `status-box status-${type}`;
                sb.style.display = "block";
                setTimeout(() => (sb.style.display = "none"), 3000);
            }

            fetchConsoles();
        </script>
    </body>
</html>
