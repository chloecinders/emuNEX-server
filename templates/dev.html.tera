<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>dev</title>
    </head>
    <body>
        <div>your role is {{ role }}</div>
        <div>
            <a href="/roms/upload">upload rom</a>
        </div>
        <div>
            <a href="/emulators/upload">upload emulator</a>
        </div>
        <div>
            <a href="/consoles/upload">upload console</a>
        </div>
        {% if role == "Admin" %}
        <div><a href="/users">manage users</a></div>
        <hr />
        <div>
            <button id="updateBtn" onclick="triggerUpdate()">pull update and restart</button>
            <p id="status"></p>
        </div>

        <script>
            async function triggerUpdate() {
                const btn = document.getElementById("updateBtn");
                const status = document.getElementById("status");

                if (!confirm("confirm restart?")) return;

                btn.disabled = true;
                status.innerText = "triggering...";

                try {
                    const response = await fetch("/admin/update", { method: "POST" });
                    const text = await response.text();

                    if (text && text.length > 0) {
                        status.innerText = "error: " + text;
                        btn.disabled = false;
                    } else {
                        status.innerText = "error: empty response";
                        btn.disabled = false;
                    }
                } catch (err) {
                    status.innerText = "restarting...";
                    setTimeout(() => location.reload(), 5000);
                }
            }
        </script>
        {% endif %}
    </body>
</html>
