<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Emulator Management | emuNEX</title>
        <link rel="stylesheet" href="/public/css/dev.css" />
    </head>
    <body>
        <div class="auth-container" style="max-width: 900px">
            <div class="auth-card">
                <header class="card-header">
                    <a href="/dev" class="back-link">Back</a>
                    <h1>emuNEX</h1>
                </header>

                <div class="content">
                    <div
                        style="
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            margin-bottom: var(--spacing-md);
                        "
                    >
                        <a href="/emulators/upload" class="popout-btn btn-fit" style="margin: 0; text-decoration: none">
                            <span class="btn-edge" style="border-radius: var(--radius-sm)"></span>
                            <span
                                class="btn-front"
                                style="
                                    padding: 6px 12px;
                                    border-radius: var(--radius-sm);
                                    font-size: 0.8rem;
                                    min-width: auto;
                                "
                                >+ Upload Emulator</span
                            >
                        </a>
                    </div>

                    <div class="form-group" style="margin-bottom: var(--spacing-md)">
                        <input
                            type="text"
                            id="emuSearch"
                            placeholder="Search emulators by name..."
                            style="font-weight: 700"
                            oninput="debounceSearch()"
                        />
                    </div>

                    <div style="overflow-x: auto">
                        <table style="margin-top: 0">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Console</th>
                                    <th>Platform</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="emulatorTableBody"> </tbody>
                        </table>
                    </div>

                    <div id="statusBox" class="status-box"></div>
                </div>
            </div>
        </div>

        <div
            id="editModal"
            style="
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.85);
                z-index: 1000;
                align-items: center;
                justify-content: center;
                padding: var(--spacing-md);
                backdrop-filter: blur(4px);
            "
        >
            <div class="auth-card" style="max-width: 600px; width: 100%; max-height: 90vh; overflow-y: auto">
                <div class="content">
                    <div class="section-hint">Edit Emulator</div>
                    <form id="editForm">
                        <input type="hidden" id="edit-id" />

                        <div class="form-group">
                            <label>Display Name</label>
                            <input type="text" id="edit-name" required />
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-md)">
                            <div class="form-group">
                                <label>Console</label>
                                <select id="edit-console" required>
                                    <option value="">select console</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Target Platform</label>
                                <select id="edit-platform" required>
                                    <option value="Windows">Windows</option>
                                    <option value="Linux">Linux</option>
                                    <option value="Android">Android</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Run Command (with args)</label>
                            <input type="text" id="edit-command" placeholder="emu.exe {rom}" />
                        </div>

                        <div class="form-group">
                            <label>Save Path (optional)</label>
                            <input type="text" id="edit-save-path" placeholder="/saves/$rom_name.sav" />
                        </div>

                        <div class="form-group">
                            <label>Configuration Files (press Enter to add)</label>
                            <div class="tag-system" id="tag-container">
                                <div class="tag-input-wrapper">
                                    <input
                                        type="text"
                                        id="tag-input"
                                        placeholder="config.ini"
                                        onkeydown="handleTagInput(event)"
                                    />
                                </div>
                            </div>
                        </div>

                        <div
                            class="form-group"
                            style="
                                flex-direction: row;
                                align-items: center;
                                gap: var(--spacing-sm);
                                margin-bottom: var(--spacing-md);
                            "
                        >
                            <input type="checkbox" id="edit-zipped" style="width: auto" />
                            <label style="margin: 0">Executable is zipped (contains DLLs/assets)</label>
                        </div>

                        <div class="form-group">
                            <label>Emulator Binary</label>
                            <label for="edit-binary" class="upload-zone" id="edit-bin-zone">
                                <div class="upload-icon">↑</div>
                                <div class="upload-info">
                                    <div class="upload-text">Upload emulator bundle</div>
                                    <div id="edit-bin-name" class="file-name"></div>
                                </div>
                                <input type="file" id="edit-binary" style="display: none" />
                            </label>
                        </div>

                        <div style="display: flex; gap: var(--spacing-md); margin-top: var(--spacing-lg)">
                            <button type="submit" class="popout-btn btn-fit btn-info" style="flex: 1; margin: 0">
                                <span class="btn-edge"></span>
                                <span class="btn-front" style="padding: 10px">Save Changes</span>
                            </button>
                            <button
                                type="button"
                                class="popout-btn btn-fit"
                                onclick="closeModal()"
                                style="flex: 1; margin: 0; --btn-color-primary: #666; --btn-color-dark: #333"
                            >
                                <span class="btn-edge"></span>
                                <span class="btn-front" style="padding: 10px">Cancel</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script>
            let searchTimeout;
            const token = localStorage.getItem("token");
            let allEmulators = [];
            let currentTags = [];

            async function fetchEmulators() {
                const body = document.getElementById("emulatorTableBody");
                body.innerHTML =
                    '<tr><td colspan="5" style="text-align: center; padding: var(--spacing-xl);">Loading emulators...</td></tr>';

                try {
                    const response = await fetch("/api/v1/emulators/all", {
                        headers: { Authorization: token },
                    });
                    const result = await response.json();

                    if (response.ok) {
                        allEmulators = result.data;
                        renderTable(allEmulators);
                    } else {
                        body.innerHTML = `<tr><td colspan="5" style="text-align: center; color: var(--color-error);">Error: ${result.error}</td></tr>`;
                    }
                } catch (err) {
                    body.innerHTML =
                        '<tr><td colspan="5" style="text-align: center; color: var(--color-error);">A network error occurred.</td></tr>';
                }
            }

            function renderTable(emulators) {
                const body = document.getElementById("emulatorTableBody");
                body.innerHTML = "";

                if (emulators.length === 0) {
                    body.innerHTML =
                        '<tr><td colspan="5" style="text-align: center; padding: var(--spacing-xl);">No emulators found.</td></tr>';
                    return;
                }

                emulators.forEach((emu) => {
                    const row = document.createElement("tr");
                    row.innerHTML = `
                        <td style="font-family: monospace; font-weight: 700; color: var(--color-text-muted);">#${emu.id}</td>
                        <td style="font-weight: 700;">${emu.name}</td>
                        <td style="font-weight: 800;">${emu.console}</td>
                        <td style="text-transform: uppercase; font-size: 0.8rem; font-weight: 700;">${emu.platform}</td>
                        <td style="display: flex; gap: var(--spacing-xs);">
                            <button class="popout-btn btn-fit btn-info" onclick="openEdit('${emu.id}')" style="margin: 0;">
                                <span class="btn-edge" style="border-radius: var(--radius-sm);"></span>
                                <span class="btn-front" style="padding: 4px 10px; border-radius: var(--radius-sm); font-size: 0.75rem; min-width: 60px;">Edit</span>
                            </button>
                            <button class="popout-btn btn-fit btn-error" onclick="deleteEmulator('${emu.id}', this)" style="margin: 0;">
                                <span class="btn-edge" style="border-radius: var(--radius-sm);"></span>
                                <span class="btn-front" style="padding: 4px 10px; border-radius: var(--radius-sm); font-size: 0.75rem; min-width: 60px;">Delete</span>
                            </button>
                        </td>
                    `;
                    body.appendChild(row);
                });
            }

            function debounceSearch() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    const q = document.getElementById("emuSearch").value.toLowerCase();
                    const filtered = allEmulators.filter(
                        (e) => e.name.toLowerCase().includes(q) || e.console.toLowerCase().includes(q),
                    );
                    renderTable(filtered);
                }, 300);
            }

            function openEdit(id) {
                const emu = allEmulators.find((e) => String(e.id) === String(id));
                if (!emu) return;

                document.getElementById("edit-id").value = emu.id;
                document.getElementById("edit-name").value = emu.name;
                document.getElementById("edit-console").value = emu.console;
                document.getElementById("edit-platform").value = emu.platform;
                document.getElementById("edit-command").value = emu.run_command;
                document.getElementById("edit-save-path").value = emu.save_path || "";
                document.getElementById("edit-zipped").checked = emu.zipped;
                document.getElementById("edit-binary").value = "";
                document.getElementById("edit-bin-name").textContent = "";

                currentTags = [...emu.config_files];
                renderTags();

                document.getElementById("editModal").style.display = "flex";
            }

            function closeModal() {
                document.getElementById("editModal").style.display = "none";
            }

            function handleTagInput(e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    const val = e.target.value.trim();
                    if (val && !currentTags.includes(val)) {
                        currentTags.push(val);
                        renderTags();
                        e.target.value = "";
                    }
                }
            }

            function renderTags() {
                const container = document.getElementById("tag-container");
                const existingTags = container.querySelectorAll(".tag");
                existingTags.forEach((t) => t.remove());

                const inputWrapper = container.querySelector(".tag-input-wrapper");

                currentTags.forEach((tag) => {
                    const tagEl = document.createElement("div");
                    tagEl.className = "tag";
                    tagEl.innerHTML = `
                        ${tag}
                        <span class="tag-remove" onclick="removeTag('${tag}')">×</span>
                    `;
                    container.insertBefore(tagEl, inputWrapper);
                });
            }

            function removeTag(tag) {
                currentTags = currentTags.filter((t) => t !== tag);
                renderTags();
            }

            document.getElementById("editForm").addEventListener("submit", async (e) => {
                e.preventDefault();
                const id = document.getElementById("edit-id").value;

                const updateData = {
                    name: document.getElementById("edit-name").value,
                    console: document.getElementById("edit-console").value,
                    platform: document.getElementById("edit-platform").value,
                    run_command: document.getElementById("edit-command").value,
                    save_path: document.getElementById("edit-save-path").value,
                    config_files: currentTags,
                    zipped: document.getElementById("edit-zipped").checked,
                };

                try {
                    const response = await fetch(`/api/v1/emulators/${id}`, {
                        method: "PUT",
                        headers: { Authorization: token, "Content-Type": "application/json" },
                        body: JSON.stringify(updateData),
                    });

                    if (!response.ok) {
                        const err = await response.json();
                        throw new Error(err.error || "Metadata update failed");
                    }

                    const binaryInput = document.getElementById("edit-binary");
                    if (binaryInput.files.length > 0) {
                        const formData = new FormData();
                        formData.append("binary", binaryInput.files[0]);
                        const bRes = await fetch(`/api/v1/emulators/${id}/binary`, {
                            method: "POST",
                            headers: { Authorization: token },
                            body: formData,
                        });
                        if (!bRes.ok) throw new Error("Binary upload failed");
                    }

                    showStatus("Emulator updated!", "success");
                    closeModal();
                    fetchEmulators();
                } catch (err) {
                    showStatus(err.message || "Update failed.", "error");
                }
            });

            async function deleteEmulator(id, btn) {
                if (!confirm(`Are you sure you want to delete emulator #${id}?`)) return;

                try {
                    const response = await fetch(`/api/v1/emulators/${id}`, {
                        method: "DELETE",
                        headers: { Authorization: token },
                    });

                    if (response.ok) {
                        btn.closest("tr").remove();
                        showStatus("Emulator deleted.", "success");
                    } else {
                        const err = await response.json();
                        showStatus(`Error: ${err.error}`, "error");
                    }
                } catch (err) {
                    showStatus("Deletion failed.", "error");
                }
            }

            function showStatus(msg, type) {
                const sb = document.getElementById("statusBox");
                sb.innerText = msg;
                sb.className = `status-box status-${type}`;
                sb.style.display = "block";
                setTimeout(() => (sb.style.display = "none"), 3000);
            }

            async function loadConsoles() {
                try {
                    const res = await fetch("/api/v1/consoles", { headers: { Authorization: token } });
                    const json = await res.json();
                    const picker = document.getElementById("edit-console");
                    (json.data || []).forEach((c) => {
                        const opt = document.createElement("option");
                        opt.value = c.name;
                        opt.textContent = c.name.toUpperCase();
                        picker.appendChild(opt);
                    });
                } catch (e) {
                    console.error("Failed to load consoles", e);
                }
            }

            loadConsoles();
            fetchEmulators();
        </script>
    </body>
</html>
