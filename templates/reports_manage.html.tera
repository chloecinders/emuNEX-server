<!DOCTYPE html>
<html lang="en">
    <head>
    <script>(function(){var t=localStorage.getItem('emunex-theme')||'light';if(t==='dark')document.documentElement.setAttribute('data-theme','dark');})();</script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>emuNEX | Manage Reports</title>
        <link rel="stylesheet" href="/public/css/index.css" />
        <link rel="icon" type="image/x-icon" href="/public/favicon.ico" />
        <script type="importmap">
            {
                "imports": {
                    "lit": "https://esm.sh/lit@3.2.1",
                    "lit/": "https://esm.sh/lit@3.2.1/",
                    "@lit/reactive-element": "https://esm.sh/@lit/reactive-element@2.0.4",
                    "@lit/reactive-element/": "https://esm.sh/@lit/reactive-element@2.0.4/",
                    "lit-html": "https://esm.sh/lit-html@3.2.1",
                    "lit-html/": "https://esm.sh/lit-html@3.2.1/",
                    "lit-element/": "https://esm.sh/lit-element@4.1.1/",
                    "lucide": "https://esm.sh/lucide@latest"
                }
            }
        </script>
        <script type="module" src="/public/js/pages/reports.js"></script>
        <link rel="icon" type="image/png" href="/public/images/32x32.png">
  </head>
    <body class="light-mode" style="margin: 0; padding: 0;">
        <emunex-reports-page role="{{ role }}" userid="{{ user_id }}"></emunex-reports-page>
    </body>
</html>
